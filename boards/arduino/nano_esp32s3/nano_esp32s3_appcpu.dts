*/

&mcpwm0 {
	status = "okay";
	#pwm-cells = <3>;
	pinctrl-0 = <&mcpwm0_default>;
	pinctrl-names = "default";
	prescale = <255>;
	prescale-timer0 = <100>;
	prescale-timer1 = <100>;
	prescale-timer2 = <100>;
};

&timer0 {
	status = "okay";
};

&timer1 {
	status = "okay";
};

