/dts-v1/;

#include <espressif/esp32s3/esp32s3_appcpu.dtsi>
#include <espressif/partitions_0x0_default_16M.dtsi>
#include "nano_esp32s3-pinctrl.dtsi"

/ {
	model = "Arduino Nano ESP32S3";
	compatible = "arduino,nano-esp32s3";

	chosen {
		zephyr,sram = &sram0;
		zephyr,ipc_shm = &shm0;
		zephyr,ipc = &ipm0;
		zephyr,console = &usb_serial;
		zephyr,shell-uart = &usb_serial;
		zephyr,flash = &flash0;
		zephyr,code-partition = &slot0_partition;
	};

	aliases {
		i2c-0 = &i2c0;
		watchdog0 = &wdt0;
		led0 = &led0;
		led1 = &led1;
		led2 = &led2;
		led3 = &led3;
	};

	leds {
		compatible = "gpio-leds";
		led0: led_0 {
			gpios = <&gpio0 0 GPIO_ACTIVE_LOW>;
			label = "Green";
		};
		led1: led_1 {
			gpios = <&gpio1 13 GPIO_ACTIVE_LOW>;
			label = "Blue";
		};
		led2: led_2 {
			gpios = <&gpio1 14 GPIO_ACTIVE_LOW>;
			label = "Red";
		};
		led3: led_3 {
			gpios = <&gpio1 16 GPIO_ACTIVE_HIGH>;
			label = "Orange";
		};
	};
};

&usb_serial {
	status = "okay";
};

&trng0 {
	status = "okay";
};

&ipm0 {
	status = "okay";
};

&gpio0 {
	status = "okay";
};

&gpio1 {
	status = "okay";
};

&wdt0 {
	status = "okay";
};

